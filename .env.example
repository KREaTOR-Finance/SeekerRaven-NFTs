SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
HELIUS_RPC_URL=https://rpc.helius.xyz/?api-key=YOUR_KEY
FALLBACK_RPC_URL=https://api.devnet.solana.com

# Base58-encoded secret key (64-byte Ed25519 secret key)
DEPLOYER_SECRET_KEY_BASE58=

# Devnet testing: use the deployed devnet token mint and its matching ATA.
SKR_MINT=BZeTDx8Hm9ygBUjRv9rCG4iFHYkAJS1jLXnfw4gbseBy
PROCEEDS_WALLET=
PROCEEDS_SKR_ATA=
# Optional aliases for older scripts/configs.
GUARDIAN_WALLET=
GUARDIAN_SKR_ATA=
# Optional legacy alias. If PROCEEDS_SKR_ATA (or GUARDIAN_SKR_ATA) is set, this is ignored.
TREASURY_SKR_ATA=
MINT_PRICE_SKR_BASE_UNITS=

# Creator wallet for metadata royalties (100% share).
CREATOR_WALLET=

# Mint window timestamps in UTC.
ALLOWLIST_START_ISO=2026-03-15T16:00:00Z
PUBLIC_START_ISO=2026-03-15T17:00:00Z

# Bot tax in lamports.
BOT_TAX_LAMPORTS=10000000

# Metadata options.
EXTERNAL_BASE_URL=https://yourdomain.com/seekerravens
COLLECTION_NAME=SeekerRavens
COLLECTION_FAMILY=SeekerRavens Genesis
SYMBOL=SRVN
ROYALTY_BPS=750
COLLECTION_MINT_OVERRIDE=

# Irys upload configuration.
# Optional override. If omitted, scripts default to:
# - devnet: https://devnet.irys.xyz
# - mainnet-beta: https://node1.irys.xyz
IRYS_NODE_URL=
# Public gateway used in minted URIs (recommended default works for both devnet + mainnet).
IRYS_GATEWAY_URL=https://gateway.irys.xyz

# Mobile / native app configuration.
BACKEND_BASE_URL=https://yourdomain.com
APP_IDENTITY_URI=https://yourdomain.com
APP_ICON_URI=favicon.ico
SIWS_DOMAIN=yourdomain.com
SIWS_STATEMENT=Sign in to SeekerRaven Mint to manage your wallet session, mint history, and holder eligibility.
PRIVACY_POLICY_URL=https://yourdomain.com/privacy
SUPPORT_URL=https://yourdomain.com/support
TERMS_OF_USE_URL=https://yourdomain.com/terms
MOBILE_AUTH_SECRET=

# Backend automation (Vercel + Neon) for on-chain SKR price updates and buyer tracking.
CANDY_MACHINE_ID=
CANDY_GUARD_ID=
JUPITER_QUOTE_URL=https://quote-api.jup.ag/v6/quote
PRICE_SYNC_SOL_INPUT_LAMPORTS=1000000000
PRICE_BUFFER_BPS=100
PRICE_UPDATE_MIN_CHANGE_BPS=100
NEON_DATABASE_URL=
CRON_SECRET=
